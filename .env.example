# Path to store model files
MODEL_DIR=/path/to/your/model/dir

# Personal GitHub access token 
GITHUB_TOKEN=your_github_token_here

# S3 bucket name for model files
MODEL_BUCKET=your-s3-bucket-name

# AWS credentials
AWS_ACCESS_KEY_ID=your_aws_access_key_id
AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
AWS_DEFAULT_REGION=your-region-n
